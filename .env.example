# Nexa AI Environment Variables

# Required: SambaNova API Key for AI responses
SAMBANOVA_API_KEY=your_api_key_here

# Required: Flask secret key for session management
# Generate with: python -c "import os; print(os.urandom(24).hex())"
SECRET_KEY=your_secret_key_here

# Security: Set to True in production with HTTPS
SESSION_COOKIE_SECURE=False

# Optional: NewsAPI key for breaking news feature
NEWSAPI_KEY=your_newsapi_key_here

# Optional: Set to production for deployment
FLASK_ENV=development
